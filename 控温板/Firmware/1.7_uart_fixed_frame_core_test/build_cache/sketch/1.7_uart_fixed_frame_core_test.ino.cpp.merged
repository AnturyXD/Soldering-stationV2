// UART fixed-frame diagnostic firmware for ATmega328P.
// Purpose: verify Arduino Core + USART0 output without OLED, ADC, PWM, PID, or menus.
// TX pin: PD1 / Arduino D1 / ATmega328P TXD
// Serial: 9600 8N1, frame: $T,999,350,0,E\n

#define UART_UBRR_9600_16MHZ 103
#define UART_INTERVAL_MS 1000UL

static uint32_t lastTxMs;

static void UartInit() {
  UBRR0H = 0;
  UBRR0L = UART_UBRR_9600_16MHZ;
  UCSR0A = 0;
  UCSR0B = _BV(TXEN0);
  UCSR0C = _BV(UCSZ01) | _BV(UCSZ00);
}

static void UartWrite(char c) {
  while (!(UCSR0A & _BV(UDRE0))) {
  }
  UDR0 = c;
}

static void UartWriteText(const char *text) {
  while (*text) {
    UartWrite(*text++);
  }
}

void setup() {
  UartInit();
  UartWriteText("BOOT\n");
  UartWriteText("$T,999,350,0,E\n");
}

void loop() {
  uint32_t now = millis();
  if ((now - lastTxMs) >= UART_INTERVAL_MS) {
    lastTxMs = now;
    UartWriteText("$T,999,350,0,E\n");
  }
}

